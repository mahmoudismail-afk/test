{
  "name": "pos-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npx opennextjs-cloudflare build --skipBuild",
    "start": "next start",
    "lint": "next lint",
    "build:worker": "node scripts/build-worker.mjs",
    "dev:worker": "wrangler dev",
    "preview:worker": "npm run build:worker && npm run dev:worker",
    "deploy:worker": "npx rimraf .open-next && npm run build:worker && wrangler deploy",
    "backup": "node backup.js",
    "sync": "node sync.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.4",
    "idb": "^8.0.3",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.0",
    "pg-connection-string": "^2.12.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^15.3.1",
    "typescript": "^5",
    "wrangler": "^4.87.0"
  }
}
